# ─────────────────────────────────────────────────────────────
# Human QR Menü — CANLI SUNUCU (.env şablonu)
# Sunucuda: cp .env.production.example .env && nano .env
# Sonra:    bash deploy/install-production.sh
# ─────────────────────────────────────────────────────────────

APP_NAME="Human Cafe"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://humansocialpeople.com
APP_LOCALE=tr
APP_FALLBACK_LOCALE=tr
APP_FAKER_LOCALE=tr_TR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# MySQL (aaPanel — SQLite canlıda kullanmayın)
# ÖNEMLİ: DB_HOST=localhost KULLANMAYIN → "No such file or directory" hatası verir
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=human_menu
DB_USERNAME=human_menu
DB_PASSWORD=DEGISTIRIN

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# Reverb: sunucuda 127.0.0.1:8080 — Nginx /app → wss (443)
REVERB_APP_ID=human-qr-menu
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=humansocialpeople.com
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_HOST=127.0.0.1
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

STAFF_UI_THEME=premium
LIVE_ORDERS_COMPLETED_RETENTION_MINUTES=120

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@humansocialpeople.com"
MAIL_FROM_NAME="${APP_NAME}"

# aaPanel / Nginx reverse proxy
TRUSTED_PROXIES=*
